{
    "name": "@openng/optimus-ui-monorepo",
    "version": "1.0.0-rc.1",
    "author": "OpenNg",
    "homepage": "https://www.openng.org/",
    "repository": {
        "type": "git",
        "url": "https://github.com/openng-org/optimus-ui.git"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/openng-org/optimus-ui/issues"
    },
    "scripts": {
        "setup": "pnpm run clean && pnpm run init",
        "clean": "npx rimraf --glob **/node_modules **/dist **/.angular ./pnpm-lock.yaml",
        "init": "pnpm install && husky",
        "link": "pnpm --filter './packages/*' dev:link",
        "release": "pnpm run build && pnpm recursive publish --filter './packages/*' --no-git-checks --report-summary",
        "release:beta": "pnpm run build && pnpm recursive publish --filter './packages/*' --no-git-checks --report-summary --tag beta",
        "release:rc": "pnpm run build && pnpm recursive publish --filter './packages/*' --no-git-checks --report-summary --tag rc",
        "build": "cross-env NODE_ENV=production pnpm run build:check && pnpm run build:packages",
        "build:check": "pnpm run format:check && pnpm run security:check",
        "build:packages": "pnpm run build:optimus-ui && pnpm run build:lib && pnpm run build:themes && pnpm run build:docs:content && pnpm run build:docs",
        "build:optimus-ui": "pnpm --filter './packages/optimus-ui-*' build",
        "build:lib": "pnpm --filter @openng/optimus-ui build",
        "build:themes": "pnpm --filter themes build",
        "build:docs": "pnpm --filter docs build",
        "build:docs:content": "pnpm --filter docs build:docs",
        "dev": "pnpm --filter docs start",
        "dev:ssr": "pnpm --filter docs start:ssr",
        "security:check": "pnpm audit --prod --audit-level high",
        "format": "prettier --write \"packages/**/*.{js,mjs,ts,mts,d.ts,html}\" \"apps/**/*.{js,mjs,ts,mts,d.ts,html}\" --cache",
        "format:check": "prettier --check \"packages/**/*.{js,mjs,ts,mts,d.ts,html}\" \"apps/**/*.{js,mjs,ts,mts,d.ts,html}\"",
        "lint": "eslint --ext \".js,.mjs,.ts,.mts\" --ignore-path .gitignore . --cache",
        "lint:fix": "eslint --fix --ext \".js,.mjs,.ts,.mts\" --ignore-path .gitignore .",
        "test:unit": "pnpm run build:optimus-ui && pnpm --filter @openng/optimus-ui test:unit",
        "test:coverage": "pnpm run build:optimus-ui && pnpm --filter @openng/optimus-ui test:unit --code-coverage"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "catalog:angular21",
        "@angular-eslint/eslint-plugin": "catalog:angular21",
        "@angular-eslint/eslint-plugin-template": "catalog:angular21",
        "@angular-eslint/schematics": "catalog:angular21",
        "@angular-eslint/template-parser": "catalog:angular21",
        "@angular/animations": "catalog:angular21",
        "@angular/cdk": "catalog:angular21",
        "@angular/cli": "catalog:angular21",
        "@angular/common": "catalog:angular21",
        "@angular/compiler": "catalog:angular21",
        "@angular/compiler-cli": "catalog:angular21",
        "@angular/core": "catalog:angular21",
        "@angular/forms": "catalog:angular21",
        "@angular/platform-browser": "catalog:angular21",
        "@angular/platform-browser-dynamic": "catalog:angular21",
        "@angular/platform-server": "catalog:angular21",
        "@angular/router": "catalog:angular21",
        "@commitlint/cli": "^19.6.1",
        "@commitlint/config-conventional": "^19.6.0",
        "@openng/optimus-ui-motion": "workspace:*",
        "@openng/optimus-ui-styled": "workspace:*",
        "@openng/optimus-ui-styles": "workspace:*",
        "@openng/optimus-ui-themes": "workspace:*",
        "@openng/optimus-ui-utils": "workspace:*",
        "@typescript-eslint/eslint-plugin": "^8.13.0",
        "cross-env": "^7.0.3",
        "eslint": "^9.14.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-jsdoc": "^50.4.3",
        "eslint-plugin-prefer-arrow": "^1.2.3",
        "eslint-plugin-prettier": "^4.2.1",
        "fs-extra": "^11.2.0",
        "glob": "^10.4.2",
        "husky": "^9.1.6",
        "lint-staged": "^12.0.0",
        "ng-packagr": "catalog:angular21",
        "pnpm": "^11.13.1",
        "prettier": "^3.0.0",
        "tsup": "^8.1.0",
        "typescript": "catalog:angular21"
    },
    "publishConfig": {
        "access": "public"
    },
    "packageManager": "pnpm@11.13.1",
    "lint-staged": {
        "packages/**/*.{js,mjs,ts,mts,d.ts,html}": [
            "prettier --write"
        ],
        "apps/**/*.{js,mjs,ts,mts,d.ts,html}": [
            "prettier --write"
        ]
    }
}
