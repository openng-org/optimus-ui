{
    "name": "@primeng/monorepo",
    "version": "22.0.0-beta.1",
    "author": "PrimeTek Informatics",
    "homepage": "https://primeng.org/",
    "repository": {
        "type": "git",
        "url": "https://github.com/primefaces/primeng.git"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/primefaces/primeng/issues"
    },
    "scripts": {
        "setup": "pnpm run clean && pnpm run init",
        "clean": "npx rimraf --glob **/node_modules **/dist **/.angular ./pnpm-lock.yaml",
        "init": "pnpm install && husky",
        "link": "pnpm --filter './packages/*' dev:link",
        "release": "pnpm run build && pnpm recursive publish --filter './packages/*' --no-git-checks --report-summary",
        "release:beta": "pnpm run build && pnpm recursive publish --filter './packages/*' --no-git-checks --report-summary --tag beta",
        "release:rc": "pnpm run build && pnpm recursive publish --filter './packages/*' --no-git-checks --report-summary --tag rc",
        "build": "cross-env NODE_ENV=production pnpm run build:check && pnpm run build:packages",
        "build:check": "pnpm run format:check && pnpm run security:check",
        "build:packages": "pnpm run build:lib && pnpm run build:themes && pnpm run build:mcp && pnpm run build:docs && pnpm run build:showcase",
        "build:lib": "pnpm --filter primeng build",
        "build:themes": "pnpm --filter themes build",
        "build:mcp": "pnpm --filter mcp build",
        "build:showcase": "pnpm --filter showcase build",
        "build:docs": "pnpm --filter showcase build:docs",
        "dev": "pnpm --filter showcase start",
        "dev:ssr": "pnpm --filter showcase start:ssr",
        "security:check": "pnpm audit --prod --audit-level high",
        "format": "prettier --write \"packages/**/*.{js,mjs,ts,mts,d.ts,html}\" \"apps/**/*.{js,mjs,ts,mts,d.ts,html}\" --cache",
        "format:check": "prettier --check \"packages/**/*.{js,mjs,ts,mts,d.ts,html}\" \"apps/**/*.{js,mjs,ts,mts,d.ts,html}\"",
        "lint": "eslint . --cache",
        "lint:fix": "eslint . --fix",
        "test:unit": "pnpm --filter primeng test:unit",
        "test:coverage": "pnpm --filter primeng test:unit --code-coverage"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "catalog:angular22",
        "@angular-eslint/eslint-plugin": "catalog:angular22",
        "@angular-eslint/eslint-plugin-template": "catalog:angular22",
        "@angular-eslint/schematics": "catalog:angular22",
        "@angular-eslint/template-parser": "catalog:angular22",
        "@angular/cdk": "catalog:angular22",
        "@angular/cli": "catalog:angular22",
        "@angular/common": "catalog:angular22",
        "@angular/compiler": "catalog:angular22",
        "@angular/compiler-cli": "catalog:angular22",
        "@angular/core": "catalog:angular22",
        "@angular/forms": "catalog:angular22",
        "@angular/platform-browser": "catalog:angular22",
        "@angular/platform-browser-dynamic": "catalog:angular22",
        "@angular/platform-server": "catalog:angular22",
        "@angular/router": "catalog:angular22",
        "@commitlint/cli": "^21.2.0",
        "@commitlint/config-conventional": "^21.2.0",
        "@eslint/js": "^10",
        "@types/node": "26.1.0",
        "angular-eslint": "^22",
        "chart.js": "4.5.1",
        "cross-env": "^10.1.0",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "fs-extra": "^11.3.6",
        "glob": "^13.0.6",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "jsdom": "29.1.1",
        "lint-staged": "^17.0.8",
        "ng-packagr": "catalog:angular22",
        "pnpm": "^11.10.0",
        "prettier": "^3.9.4",
        "quill": "2.0.3",
        "tsup": "^8.5.1",
        "typescript": "catalog:angular22",
        "typescript-eslint": "^8.62.1",
        "vitest": "4.1.10"
    },
    "publishConfig": {
        "access": "public"
    },
    "packageManager": "pnpm@11.10.0",
    "engines": {
        "node": "^22.22.3 || ^24.15.0 || >=26.0.0"
    },
    "lint-staged": {
        "packages/**/*.{js,mjs,ts,mts,d.ts,html}": [
            "prettier --write"
        ],
        "apps/**/*.{js,mjs,ts,mts,d.ts,html}": [
            "prettier --write"
        ]
    }
}