{
    "name": "@openng/optimus-ui-themes",
    "version": "2.0.3",
    "author": "OpenNG",
    "description": "Themes for Optimus UI Libraries",
    "keywords": [
        "themes",
        "css",
        "style utilities",
        "optimus-ui",
        "angular"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/openng-org/optimus-ui.git",
        "directory": "packages/themes"
    },
    "bugs": {
        "url": "https://github.com/openng-org/optimus-ui/issues"
    },
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs",
            "default": "./dist/index.mjs"
        },
        "./types": {
            "types": "./types/index.d.ts"
        },
        "./types/*": {
            "types": "./types/*/index.d.ts"
        },
        "./tokens": {
            "types": "./tokens/index.d.ts",
            "import": "./tokens/index.mjs",
            "default": "./tokens/index.mjs"
        },
        "./*": {
            "types": "./dist/*/index.d.ts",
            "import": "./dist/*/index.mjs",
            "default": "./dist/*/index.mjs"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "sideEffects": false,
    "files": [
        "dist",
        "umd",
        "tokens",
        "types",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "cross-env NODE_ENV=production INPUT_DIR=src/ OUTPUT_DIR=dist/ pnpm run build:package",
        "build:dev": "cross-env NODE_ENV=development INPUT_DIR=src/ OUTPUT_DIR=dist/ pnpm run build:dev:package",
        "build:package": "pnpm run type:check && pnpm run build:tokens && tsup && pnpm run build:postbuild",
        "build:dev:package": "pnpm run build:tokens && tsup --watch && pnpm run build:postbuild",
        "build:postbuild": "node ./scripts/postbuild.mjs",
        "build:tokens": "node ./scripts/build-tokens.mjs",
        "type:check": "tsc --noEmit",
        "dev:link": "pnpm link --global && npm link"
    },
    "dependencies": {
        "@openng/optimus-ui-styled": "workspace:*"
    },
    "devDependencies": {
        "typedoc": "0.27.6"
    }
}
