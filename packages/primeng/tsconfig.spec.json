{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "strictNullChecks": true,
        "types": [
            "vitest/globals",
            "node"
        ],
        "outDir": "./out-tsc/spec"
    },
    "angularCompilerOptions": {
        "strictTemplates": false,
        "fullTemplateTypeCheck": false
    },
    "exclude": [
        "node_modules"
    ],
    "include": [
        "src/**/*.spec.ts",
        "src/**/*.d.ts",
        "src/test-setup.ts"
    ]
}