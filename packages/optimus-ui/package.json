{
    "name": "@openng/optimus-ui",
    "version": "21.1.9",
    "author": "OpenNg",
    "description": "OptimusUI is an open source UI library for Angular featuring a rich set of 80+ components, a theme designer, various theme alternatives such as Material, Bootstrap and Tailwind",
    "homepage": "https://www.openng.org/",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/openng-org/optimus-ui.git",
        "directory": "packages/optimus-ui"
    },
    "bugs": {
        "url": "https://github.com/openng-org/optimus-ui/issues"
    },
    "keywords": [
        "optimus",
        "optimusui",
        "angular",
        "ui library",
        "component library",
        "material",
        "bootstrap",
        "fluent",
        "tailwind"
    ],
    "publishConfig": {
        "directory": "dist",
        "linkDirectory": false,
        "access": "public"
    },
    "scripts": {
        "build": "cross-env NODE_ENV=production INPUT_DIR=src/ OUTPUT_DIR=dist/ pnpm run build:package",
        "build:package": "pnpm run build:prebuild && ng build optimus-ui && pnpm run build:postbuild",
        "build:prebuild": "node ./scripts/prebuild.mjs",
        "build:postbuild": "node ./scripts/postbuild.mjs",
        "dev:link": "pnpm link --global && npm link",
        "lint": "ng lint",
        "test:unit": "ng test optimus-ui --watch=false --browsers=ChromeHeadless",
        "test:unit:watch": "ng test optimus-ui",
        "test:unit:coverage": "ng test optimus-ui --coverage",
        "test:vitest": "ng run optimus-ui:test-vitest --watch=false",
        "test:vitest:watch": "ng run optimus-ui:test-vitest --watch",
        "test:vitest:coverage": "ng run optimus-ui:test-vitest --watch=false --coverage"
    },
    "devDependencies": {
        "@angular/build": "catalog:angular21",
        "@vitest/browser-playwright": "^4.0.8",
        "@vitest/coverage-v8": "^4.0.8",
        "karma": "~6.4.4",
        "karma-chrome-launcher": "~3.2.0",
        "karma-coverage": "~2.2.1",
        "karma-jasmine": "~5.1.0",
        "karma-jasmine-html-reporter": "~2.1.0",
        "tslib": "^2.8.1",
        "vitest": "^4.0.8"
    },
    "peerDependencies": {
        "@angular/cdk": "catalog:angular21",
        "@angular/common": "catalog:angular21",
        "@angular/core": "catalog:angular21",
        "@angular/forms": "catalog:angular21",
        "@angular/router": "catalog:angular21",
        "@angular/platform-browser": "catalog:angular21",
        "rxjs": "^6.0.0 || ^7.8.1"
    },
    "dependencies": {
        "@openng/optimus-ui-styled": "workspace:*",
        "@openng/optimus-ui-utils": "workspace:*",
        "@openng/optimus-ui-styles": "workspace:*",
        "@openng/optimus-ui-motion": "workspace:*"
    }
}
