{
    "name": "@openng/optimus-ui-motion",
    "version": "0.0.10",
    "author": "OpenNG",
    "description": "Motion utilities for Optimus UI Libraries",
    "keywords": ["motion", "animation", "transition", "composition utilities", "optimus-ui", "angular"],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/openng-org/optimus-ui.git",
        "directory": "packages/optimus-ui-motion"
    },
    "bugs": {
        "url": "https://github.com/openng-org/optimus-ui/issues"
    },
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs",
            "default": "./dist/index.mjs"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "sideEffects": false,
    "files": ["dist", "README.md", "LICENSE"],
    "scripts": {
        "build": "cross-env NODE_ENV=production INPUT_DIR=src/ OUTPUT_DIR=dist/ pnpm run build:package",
        "build:dev": "cross-env NODE_ENV=development INPUT_DIR=src/ OUTPUT_DIR=dist/ pnpm run build:dev:package",
        "build:package": "tsdown",
        "build:dev:package": "tsdown --watch",
        "dev:link": "pnpm link --global && npm link"
    },
    "dependencies": {
        "@openng/optimus-ui-utils": "workspace:*"
    },
    "engines": {
        "node": ">=12.11.0"
    }
}
