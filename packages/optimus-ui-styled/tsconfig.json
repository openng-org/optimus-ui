{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "target": "es2016",
        "paths": {
            "@openng/optimus-ui-utils": [
                "../optimus-ui-utils/src"
            ],
            "@openng/optimus-ui-utils/*": [
                "../optimus-ui-utils/src/*"
            ],
            "@openng/optimus-ui-styled": [
                "../optimus-ui-styled/src"
            ],
            "@openng/optimus-ui-styled/*": [
                "../optimus-ui-styled/src/*"
            ],
            "@openng/optimus-ui-styles": [
                "../optimus-ui-styles/src"
            ],
            "@openng/optimus-ui-styles/*": [
                "../optimus-ui-styles/src/*"
            ],
            "@openng/optimus-ui-motion": [
                "../optimus-ui-motion/src"
            ],
            "@openng/optimus-ui-motion/*": [
                "../optimus-ui-motion/src/*",
                "../optimus-ui-motion/types/*"
            ],
            "@openng/optimus-ui-themes": [
                "../optimus-ui-themes/src"
            ],
            "@openng/optimus-ui-themes/types": [
                "../optimus-ui-themes/types"
            ],
            "@openng/optimus-ui-themes/types/*": [
                "../optimus-ui-themes/types/*"
            ],
            "@openng/optimus-ui-themes/*": [
                "../optimus-ui-themes/src/*",
                "../optimus-ui-themes/src/presets/*",
                "../optimus-ui-themes/types/*"
            ]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
